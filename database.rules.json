{
  "rules": {
    ".read": "auth != null",
    ".write": "auth.token.email === 'admin@shifts-ta26.com'",
    "schedules": {
      "$week": {
        "pendingRequests": {
          "$reqId": {
            ".write": "auth != null && !data.exists()"
          }
        }
      }
    },
    "myRequests": {
      "$empId": {
        "$reqId": {
          ".write": "auth != null && !data.exists()"
        }
      }
    },
    "pendingRequestsIndex": {
      "$reqId": {
        ".write": "auth != null && !data.exists()"
      }
    },
    "forceDemands": {
      "$id": {
        ".write": "auth != null && !data.exists()"
      }
    },
    "passwordOverrides": {
      "$empId": {
        ".write": "auth != null"
      }
    }
  }
}
